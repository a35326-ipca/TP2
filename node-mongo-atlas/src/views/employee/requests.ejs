<%- include("../partials/app-start") %>

<%
  const currentDecisionStatus =
    typeof selectedDecisionStatus !== "undefined"
      ? selectedDecisionStatus
      : ((reviewingRequest && ["rejeitado", "aprovado"].includes(reviewingRequest.status || "")) ? reviewingRequest.status : "aprovado");
  const currentDecisionNotes =
    typeof decisionNotesValue !== "undefined"
      ? decisionNotesValue
      : (reviewingRequest?.decisionNotes || "");
  const totalDecisionHistory =
    typeof decisionHistoryCount !== "undefined"
      ? decisionHistoryCount
      : (decisionHistory?.length || 0);
%>

<% if (reviewingRequest) { %>
  <%
    const studentName = reviewingRequest.userId?.name || "-";
    const studentInitial = (studentName.trim().charAt(0) || "?").toUpperCase();
    const studentPhotoSrc = reviewingRequest.studentPhotoPath ? assetPath(reviewingRequest.studentPhotoPath) : null;
  %>
  <div class="app-modal is-open" id="review-request-modal">
    <a href="/funcionario/matriculas" class="app-modal__backdrop" aria-label="Fechar revisão da matrícula" data-modal-close></a>
    <section class="app-modal__dialog app-modal__dialog--review app-panel profile-panel" role="dialog" aria-modal="true" aria-labelledby="review-request-title">
      <div class="app-modal__header">
        <div>
          <h2 id="review-request-title"><%= ["rejeitado", "aprovado"].includes(reviewingRequest.status || "") ? "Editar matrícula" : "Rever matrícula" %></h2>
          <p class="app-text-flow"><%= studentName %> · <%= reviewingRequest.courseId?.name || "-" %></p>
        </div>
        <a href="/funcionario/matriculas" class="app-modal__close" aria-label="Fechar modal" data-modal-close>
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </a>
      </div>

      <div class="review-profile-grid">
        <article class="app-card review-profile-card review-profile-card--details">
          <h2>Dados submetidos</h2>
          <div class="review-profile-details">
            <p><strong>Aluno:</strong> <span class="app-text-flow--scroll"><%= studentName %></span></p>
            <p><strong>E-mail:</strong> <span class="app-text-flow--scroll"><%= reviewingRequest.userId?.email || "-" %></span></p>
            <p><strong>Curso:</strong> <span class="app-text-flow--scroll"><%= reviewingRequest.courseId?.name || "-" %></span></p>
            <p><strong>Estado atual:</strong> <span class="app-text-flow"><%- include("../partials/status-badge", { status: reviewingRequest.status }) %></span></p>
            <p><strong>Submetido em:</strong> <span class="app-text-flow"><%= reviewingRequest.createdAt ? formatDate(reviewingRequest.createdAt) : "-" %></span></p>
            <p><strong>Decidido por:</strong> <span class="app-text-flow--scroll"><%= reviewingRequest.decidedBy?.name || "-" %></span></p>
            <p><strong>Data da decisão:</strong> <span class="app-text-flow"><%= reviewingRequest.decidedAt ? new Date(reviewingRequest.decidedAt).toISOString().slice(0, 16).replace("T", " ") : "-" %></span></p>
            <p class="review-field--stacked"><strong>Observações do aluno:</strong> <span class="app-text-flow--scroll"><%= reviewingRequest.studentNotes || "-" %></span></p>
            <p class="review-field--stacked"><strong>Observações atuais:</strong> <span class="app-text-flow--scroll"><%= reviewingRequest.decisionNotes || "-" %></span></p>
          </div>
        </article>

        <article class="app-card review-profile-card review-profile-card--photo">
          <h2>Fotografia do aluno</h2>
          <p class="helper-text">Aqui está a fotografia submetida pelo aluno.</p>
          <div class="review-profile-photo-wrap">
            <% if (studentPhotoSrc) { %>
              <img
                src="<%= studentPhotoSrc %>"
                alt="Fotografia do aluno"
                class="photo-preview photo-preview--modal"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                onerror="this.classList.add('is-hidden'); this.nextElementSibling?.classList.add('is-visible');"
              >
              <div class="photo-placeholder photo-placeholder--modal" aria-hidden="true">
                <span class="photo-placeholder__initial"><%= studentInitial %></span>
              </div>
            <% } else { %>
              <div class="photo-placeholder photo-placeholder--modal is-visible" aria-label="Sem fotografia submetida">
                <span class="photo-placeholder__initial"><%= studentInitial %></span>
              </div>
            <% } %>
          </div>
        </article>

        <article class="app-card review-profile-card review-profile-card--decision">
          <h2>Decisão pedagógica</h2>
          <form method="post" action="/funcionario/matriculas/<%= reviewingRequest._id %>/decisao" class="app-form review-profile-form" novalidate>
            <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

            <div class="app-field">
              <label for="status">Decisão</label>
              <select id="status" name="status">
                <option value="aprovado" <%= currentDecisionStatus === "aprovado" ? "selected" : "" %>>Aprovar</option>
                <option value="rejeitado" <%= currentDecisionStatus === "rejeitado" ? "selected" : "" %>>Rejeitar</option>
              </select>
            </div>
            <div class="app-field review-profile-notes-field">
              <label for="decision_notes">Observações do funcionário</label>
              <textarea id="decision_notes" name="decision_notes" class="review-profile-notes"><%= currentDecisionNotes %></textarea>
            </div>
            <div class="app-form__actions review-profile-actions">
              <button type="submit" class="app-button app-button--primary">Guardar decisão</button>
            </div>
          </form>
        </article>

        <article class="app-card review-profile-card review-profile-card--history">
          <h2>Histórico de decisões</h2>
          <% if (!decisionHistory || !decisionHistory.length) { %>
            <p class="empty-text">Ainda não existem decisões anteriores registadas para este pedido.</p>
          <% } else { %>
            <% if (totalDecisionHistory > decisionHistory.length) { %>
              <p class="helper-text">A mostrar as 5 decisões mais recentes.</p>
            <% } %>
            <div class="decision-history">
              <% decisionHistory.forEach((historyItem) => { %>
                <article class="decision-history__item">
                  <div class="decision-history__meta">
                    <strong class="app-text-flow"><%= historyItem.decidedBy?.name || "Sistema" %></strong>
                    <span class="app-text-flow"><%= historyItem.createdAt ? new Date(historyItem.createdAt).toISOString().slice(0, 16).replace("T", " ") : "-" %></span>
                  </div>
                  <p><strong>Estado:</strong> <span class="app-text-flow"><%= historyItem.previousStatus %> → <%= historyItem.newStatus %></span></p>
                  <p class="review-field--stacked"><strong>Observações anteriores:</strong> <span class="app-text-flow--scroll"><%= historyItem.previousDecisionNotes || "-" %></span></p>
                  <p class="review-field--stacked"><strong>Novas observações:</strong> <span class="app-text-flow--scroll"><%= historyItem.newDecisionNotes || "-" %></span></p>
                </article>
              <% }) %>
            </div>
          <% } %>
        </article>
      </div>
    </section>
  </div>
<% } %>

<% if (deleteCandidate) { %>
  <div class="app-modal is-open" id="delete-request-modal">
    <a href="/funcionario/matriculas" class="app-modal__backdrop" aria-label="Fechar confirmação de eliminação"></a>

    <section class="app-modal__dialog app-panel profile-panel app-modal__dialog--compact" role="dialog" aria-modal="true" aria-labelledby="delete-request-title">
      <div class="app-modal__header">
        <div>
          <h2 id="delete-request-title">Apagar matrícula rejeitada</h2>
          <p>Vais apagar o pedido de <strong><%= deleteCandidate.userId?.name || "-" %></strong> para o curso <strong><%= deleteCandidate.courseId?.name || "-" %></strong>.</p>
        </div>
        <a href="/funcionario/matriculas" class="app-modal__close" aria-label="Fechar modal">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </a>
      </div>

      <div class="app-modal__content">
        <p class="helper-text">Esta ação remove definitivamente o pedido e o respetivo histórico de decisões.</p>
        <p class="helper-text">Submetido em: <strong><%= deleteCandidate.createdAt ? formatDate(deleteCandidate.createdAt) : "-" %></strong></p>
      </div>

      <form method="post" action="/funcionario/matriculas/<%= deleteCandidate._id %>/delete" class="app-form" novalidate>
        <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

        <div class="app-form__actions app-modal__actions app-modal__actions--single">
          <button type="submit" class="app-button app-button--danger">Confirmar eliminação</button>
        </div>
      </form>
    </section>
  </div>
<% } %>

<% if (reviewingRequest || deleteCandidate) { %>
  <script>
    document.body.classList.add("app-modal-open");

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        window.location.href = "/funcionario/matriculas";
      }
    });
  </script>
<% } %>

<section class="app-panel">
  <div class="app-panel__header">
    <div>
      <h2>Gestão de matrículas registadas</h2>
      <p>A prioridade visual é dada aos pedidos pendentes, permitindo ao funcionário gerir as matrículas submetidas pelos alunos de forma eficiente. Todas as decisões ficam registadas e podem ser consultadas no histórico de cada processo.</p>
    </div>
  </div>

  <div class="app-table-wrap">
    <table class="app-table app-table--profiles">
      <thead>
        <tr>
          <th class="app-table__profile-student-col">Aluno</th>
          <th class="app-table__profile-email-col">E-mail</th>
          <th class="app-table__profile-course-col">Curso</th>
          <th class="app-table__profile-submitted-col">Submetida</th>
          <th class="app-table__profile-status-col">Estado</th>
          <th class="app-table__profile-actions-col">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!requests.length) { %>
          <tr>
            <td colspan="6"><p class="empty-text">Não existem pedidos registados.</p></td>
          </tr>
        <% } %>
        <% requests.forEach((request) => { %>
          <tr>
            <td class="app-table__profile-student-col"><div class="app-text-flow--scroll"><%= request.userId?.name || "-" %></div></td>
            <td class="app-table__profile-email-col"><div class="app-text-flow--scroll"><%= request.userId?.email || "-" %></div></td>
            <td class="app-table__profile-course-col"><div class="app-text-flow--scroll"><%= request.courseId?.name || "-" %></div></td>
            <td class="app-table__profile-submitted-col"><%= request.createdAt ? formatDate(request.createdAt) : "-" %></td>
            <td class="app-table__profile-status-col"><%- include("../partials/status-badge", { status: request.status }) %></td>
            <td class="app-table__profile-actions-col">
              <div class="table-actions">
                <% if ((request.status || "") === "pendente") { %>
                  <a href="/funcionario/matriculas?review=<%= request._id %>" data-modal-url="/funcionario/matriculas?review=<%= request._id %>" title="Rever">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                    </svg>
                  </a>
                <% } else if (["rejeitado", "aprovado"].includes(request.status || "")) { %>
                  <a href="/funcionario/matriculas?review=<%= request._id %>" data-modal-url="/funcionario/matriculas?review=<%= request._id %>" title="Editar">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                    </svg>
                  </a>
                  <% if ((request.status || "") === "rejeitado") { %>
                    <a href="/funcionario/matriculas?confirm_delete=<%= request._id %>" class="danger" title="Apagar">
                      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.11 0 0 0-7.5 0" />
                      </svg>
                    </a>
                  <% } %>
                <% } else { %>
                  <span class="helper-text">Fechado</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/app-end") %>
