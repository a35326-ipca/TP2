<%- include("../partials/app-start") %>

<%
  const currentReviewStatus =
    typeof selectedReviewStatus !== "undefined"
      ? selectedReviewStatus
      : ((reviewingProfile && ["rejeitada", "aprovada"].includes(reviewingProfile.status || "")) ? reviewingProfile.status : "aprovada");
  const currentReviewNotes =
    typeof reviewNotesValue !== "undefined"
      ? reviewNotesValue
      : (reviewingProfile?.reviewNotes || "");
  const totalDecisionHistory =
    typeof decisionHistoryCount !== "undefined"
      ? decisionHistoryCount
      : (decisionHistory?.length || 0);
%>

<% if (reviewingProfile) { %>
  <%
    const profileName = reviewingProfile.fullName || reviewingProfile.userId?.name || "-";
    const profileInitial = (profileName.trim().charAt(0) || "?").toUpperCase();
    const profilePhotoSrc = reviewingProfile.photoPath ? assetPath(reviewingProfile.photoPath) : null;
  %>
  <div class="app-modal is-open" id="review-profile-modal">
    <a href="/gestor/fichas" class="app-modal__backdrop" aria-label="Fechar revisão da ficha"></a>
    <section class="app-modal__dialog app-modal__dialog--review app-panel profile-panel" role="dialog" aria-modal="true" aria-labelledby="review-profile-title">
      <div class="app-modal__header">
        <div>
          <h2 id="review-profile-title"><%= ["rejeitada", "aprovada"].includes(reviewingProfile.status || "") ? "Editar ficha" : "Rever ficha" %></h2>
          <p><%= profileName %> · <%= reviewingProfile.courseId?.name || "-" %></p>
        </div>
        <a href="/gestor/fichas" class="app-modal__close" aria-label="Fechar modal">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </a>
      </div>

      <div class="review-profile-grid">
        <article class="app-card review-profile-card review-profile-card--details">
          <h2>Dados submetidos</h2>
          <div class="review-profile-details">
            <p><strong>Nome:</strong> <%= profileName %></p>
            <p><strong>Data de nascimento:</strong> <%= formatDate(reviewingProfile.birthDate) %></p>
            <p><strong>E-mail da conta:</strong> <%= reviewingProfile.userId?.email || "-" %></p>
            <p><strong>E-mail de contacto:</strong> <%= reviewingProfile.contactEmail || "-" %></p>
            <p><strong>Telefone:</strong> <%= reviewingProfile.phone || "-" %></p>
            <p><strong>Morada:</strong> <%= reviewingProfile.address || "-" %></p>
            <p><strong>Curso:</strong> <%= reviewingProfile.courseId?.name || "-" %></p>
            <p><strong>Estado atual:</strong> <%- include("../partials/status-badge", { status: reviewingProfile.status }) %></p>
            <p class="review-field--stacked"><strong>Observações do aluno:</strong> <span class="app-text-flow--scroll"><%= reviewingProfile.notes || "-" %></span></p>
          </div>
        </article>

        <article class="app-card review-profile-card review-profile-card--photo">
          <h2>Fotografia do aluno</h2>
          <p class="helper-text">Aqui está a fotografia submetida pelo aluno.</p>
          <div class="review-profile-photo-wrap">
            <% if (profilePhotoSrc) { %>
              <img
                src="<%= profilePhotoSrc %>"
                alt="Fotografia do aluno"
                class="photo-preview photo-preview--modal"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                onerror="this.classList.add('is-hidden'); this.nextElementSibling?.classList.add('is-visible');"
              >
              <div class="photo-placeholder photo-placeholder--modal" aria-hidden="true">
                <span class="photo-placeholder__initial"><%= profileInitial %></span>
              </div>
            <% } else { %>
              <div class="photo-placeholder photo-placeholder--modal is-visible" aria-label="Sem fotografia submetida">
                <span class="photo-placeholder__initial"><%= profileInitial %></span>
              </div>
            <% } %>
          </div>
        </article>

        <article class="app-card review-profile-card review-profile-card--decision">
          <h2>Decisão pedagógica</h2>
          <form method="post" action="/gestor/fichas/<%= reviewingProfile._id %>/revisao" class="app-form review-profile-form" novalidate>
            <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

            <div class="app-field">
              <label for="status">Decisão</label>
              <select id="status" name="status">
                <option value="aprovada" <%= currentReviewStatus === "aprovada" ? "selected" : "" %>>Aprovar</option>
                <option value="rejeitada" <%= currentReviewStatus === "rejeitada" ? "selected" : "" %>>Rejeitar</option>
              </select>
            </div>
            <div class="app-field review-profile-notes-field">
              <label for="review_notes">Observações do gestor</label>
              <textarea id="review_notes" name="review_notes" class="review-profile-notes"><%= currentReviewNotes %></textarea>
            </div>
            <div class="app-form__actions review-profile-actions">
              <button type="submit" class="app-button app-button--primary">Guardar decisão</button>
            </div>
          </form>
        </article>

        <article class="app-card review-profile-card review-profile-card--history">
          <h2>Histórico de decisões</h2>
          <% if (!decisionHistory || !decisionHistory.length) { %>
            <p class="empty-text">Ainda não existem decisões anteriores registadas para esta ficha.</p>
          <% } else { %>
            <% if (totalDecisionHistory > decisionHistory.length) { %>
              <p class="helper-text">A mostrar as 5 decisões mais recentes.</p>
            <% } %>
            <div class="decision-history">
              <% decisionHistory.forEach((historyItem) => { %>
                <article class="decision-history__item">
                  <div class="decision-history__meta">
                    <strong class="app-text-flow"><%= historyItem.reviewedBy?.name || "Sistema" %></strong>
                    <span class="app-text-flow"><%= historyItem.createdAt ? new Date(historyItem.createdAt).toISOString().slice(0, 16).replace("T", " ") : "-" %></span>
                  </div>
                  <p><strong>Estado:</strong> <span class="app-text-flow"><%= historyItem.previousStatus %> → <%= historyItem.newStatus %></span></p>
                  <p class="review-field--stacked"><strong>Observações anteriores:</strong> <span class="app-text-flow--scroll"><%= historyItem.previousReviewNotes || "-" %></span></p>
                  <p class="review-field--stacked"><strong>Novas observações:</strong> <span class="app-text-flow--scroll"><%= historyItem.newReviewNotes || "-" %></span></p>
                </article>
              <% }) %>
            </div>
          <% } %>
        </article>
      </div>
    </section>
  </div>
<% } %>

<% if (deleteCandidate) { %>
  <div class="app-modal is-open" id="delete-profile-modal">
    <a href="/gestor/fichas" class="app-modal__backdrop" aria-label="Fechar confirmação de eliminação"></a>

    <section class="app-modal__dialog app-panel profile-panel app-modal__dialog--compact" role="dialog" aria-modal="true" aria-labelledby="delete-profile-title">
      <div class="app-modal__header">
        <div>
          <h2 id="delete-profile-title">Eliminar ficha</h2>
          <p>Vais remover a ficha de <strong><%= deleteCandidate.fullName || "-" %></strong>.</p>
        </div>
        <a href="/gestor/fichas" class="app-modal__close" aria-label="Fechar modal">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </a>
      </div>

      <div class="app-modal__content">
        <p class="helper-text">Curso: <strong><%= deleteCandidate.courseId?.name || "-" %></strong></p>
        <p class="helper-text">Estado: <strong><%= deleteCandidate.status || "-" %></strong></p>
        <p class="helper-text">Submetida: <strong><%= deleteCandidate.submittedAt ? formatDate(deleteCandidate.submittedAt) : "-" %></strong></p>
        <% if ((deleteCandidate.status || "") === "rejeitada") { %>
          <p class="helper-text">Por se tratar de uma ficha rejeitada, a eliminação definitiva será concluída automaticamente após <strong>10 dias</strong>.</p>
        <% } else { %>
          <p class="helper-text">Esta ação remove a ficha de forma imediata.</p>
        <% } %>
      </div>

      <form method="post" action="/gestor/fichas/<%= deleteCandidate._id %>/delete" class="app-form" novalidate>
        <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

        <div class="app-form__actions app-modal__actions app-modal__actions--single">
          <button type="submit" class="app-button app-button--danger">Confirmar eliminação</button>
        </div>
      </form>
    </section>
  </div>
<% } %>

<% if (reviewingProfile || deleteCandidate) { %>
  <script>
    document.body.classList.add("app-modal-open");

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        window.location.href = "/gestor/fichas";
      }
    });
  </script>
<% } %>

<section class="app-panel">
  <div class="app-panel__header">
    <div>
      <h2>Gestão de Fichas</h2>
      <p>Nesta secção podes consultar todas as fichas registadas, ver os dados dos alunos, acompanhar o estado de cada submissão e realizar ações como editar ou remover quando necessário.</p>
    </div>
  </div>

  <div class="app-table-wrap">
    <table class="app-table app-table--profiles">
      <thead>
        <tr>
          <th class="app-table__profile-student-col">Aluno</th>
          <th class="app-table__profile-email-col">E-mail</th>
          <th class="app-table__profile-phone-col">Telefone</th>
          <th class="app-table__profile-course-col">Curso</th>
          <th class="app-table__profile-submitted-col">Submetida</th>
          <th class="app-table__profile-status-col">Estado</th>
          <th class="app-table__profile-actions-col">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% profiles.forEach((profile) => { %>
          <tr>
            <td class="app-table__profile-student-col"><%= profile.fullName || "-" %></td>
            <td class="app-table__profile-email-col"><%= profile.contactEmail || "-" %></td>
            <td class="app-table__profile-phone-col"><%= profile.phone || "-" %></td>
            <td class="app-table__profile-course-col"><%= profile.courseId?.name || "-" %></td>
            <td class="app-table__profile-submitted-col"><%= profile.submittedAt ? formatDate(profile.submittedAt) : "-" %></td>
            <td class="app-table__profile-status-col"><%- include("../partials/status-badge", { status: profile.status }) %></td>
            <td class="app-table__profile-actions-col">
              <div class="table-actions">
                <% if ((profile.status || "") === "submetida") { %>
                  <a href="/gestor/fichas?review=<%= profile._id %>" title="Rever">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                    </svg>
                  </a>
                <% } else if (["rejeitada", "aprovada"].includes(profile.status || "")) { %>
                  <a href="/gestor/fichas?review=<%= profile._id %>" title="Editar">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                    </svg>
                  </a>
                  <a href="/gestor/fichas?confirm_delete=<%= profile._id %>" class="danger" title="Eliminar">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.11 0 0 0-7.5 0" />
                    </svg>
                  </a>
                <% } else { %>
                  <span class="helper-text">Fechada</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/app-end") %>
